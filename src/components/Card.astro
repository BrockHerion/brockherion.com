---
interface Props {
  class?: string;
  href?: string;
}

const { class: className = '', href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'bg-card rounded-lg shadow-sm border border-border p-5 block',
    href && 'transition-shadow hover:shadow-md group',
    className,
  ]}
>
  <slot />
</Tag>
